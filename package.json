{
  "name": "fetch-techer",
  "private": true,
  "workspaces": [
    "front",
    "backend"
  ],
  "scripts": {
    "dev:front": "npm --workspace front run dev",
    "dev:back": "npm --workspace backend run dev",
    "dev": "npm-run-all -p dev:front dev:back",
    "test:front": "npm --workspace front test",
    "test:back": "npm --workspace backend test",
    "test": "npm-run-all test:front test:back",
    "build:front": "npm --workspace front run build",
    "build:back": "npm --workspace backend run build",
    "build": "npm-run-all build:front build:back",
    "start:front": "npm --workspace front run start",
    "start:back": "npm --workspace backend run start",
    "start": "npm-run-all -p start:back start:front"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
